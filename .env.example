# Dynamic config: set these so you don't need to pass repo path every time.
# Works with any clone (GitHub, GitLab private, etc.) — clone with your SSH key or PAT first, then set path here.

# Path to your local clone of the migration repo (required if not passing --repo-path / repo_path in code)
# PG_DB2_GIT_SYNC_REPO_PATH=C:\path\to\66degrees-database-migration

# Optional: override defaults
# PG_DB2_GIT_SYNC_TARGET_DDL_BASE=target_ddl
# PG_DB2_GIT_SYNC_DEFAULT_ENV=non_prod

# Remote Git access for playground/tests
# GIT_TOKEN=glpat-...

# Optional Azure AD app registration (defaults to Azure CLI public client ID)
# AZURE_CLIENT_ID=04b07795-8ddb-461a-bbee-02f9e1bf7b46
